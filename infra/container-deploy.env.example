# ═══════════════════════════════════════════════════════════════════════════
# McCain Portal — Container Deploy — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file, fill in your values, then source it before deploying:
#   cp infra/container-deploy.env.example infra/.deploy.env
#   # Edit infra/.deploy.env with your real values
#   source infra/.deploy.env && ./infra/container-deploy.sh
# ═══════════════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Azure Database for PostgreSQL Flexible Server:
DATABASE_URL=postgresql://adminuser:YourP@ssw0rd@mccain-portal-db.postgres.database.azure.com:5432/portaldb?sslmode=require

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-char-random-hex

# ── Azure OpenAI (Recommended) ───────────────────────────────────────────────
# From Azure Portal → Azure OpenAI resource → Keys & Endpoint

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Standard OpenAI (Alternative — only if NOT using Azure OpenAI) ───────────
# OPENAI_API_KEY=sk-...

# ── Optional ─────────────────────────────────────────────────────────────────

# CORS — leave empty (single container serves both API and frontend)
ALLOWED_ORIGIN=

# Azure Service Principal for IaC deployment feature
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# Confluence publishing
# CONFLUENCE_BASE_URL=https://your-org.atlassian.net
# CONFLUENCE_USERNAME=your-email@mccain.com
# CONFLUENCE_API_TOKEN=
# CONFLUENCE_SPACE_KEY=CLOUD
# CONFLUENCE_PARENT_PAGE_ID=
