# ============================================================
# McCain Unified Onboarding Portal — React Frontend
# Environment Variables for Azure Deployment
# ============================================================
# All variables must start with VITE_ to be included in the build.
#
# Option A — Single App Service (recommended, cheapest):
#   Leave VITE_API_URL empty. The frontend will call /api on the
#   same host (Express serves both the static files and the API).
#
# Option B — Separate hosting (Static Web Apps + App Service):
#   Set VITE_API_URL to your API App Service URL.
# ============================================================

# API server base URL.
# Leave EMPTY if frontend is served by the same Express API server (Option A).
# Set to full URL if hosted separately (Option B):
# VITE_API_URL=https://mccain-portal-api.azurewebsites.net
VITE_API_URL=

# Base path — leave as "/" unless hosting at a sub-path.
BASE_PATH=/
