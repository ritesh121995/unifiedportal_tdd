# ============================================================
# McCain Unified Onboarding Portal — API Server
# Environment Variables for Azure App Service Deployment
# ============================================================
# Copy this file to .env for local development.
# For Azure, set these in:
#   App Service → Settings → Environment variables
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Azure App Service sets PORT automatically — do NOT override it.
# Locally, set to 8080.
PORT=8080

# Set to "production" on Azure App Service.
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────
# Must be set in production. Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret-min-64-chars

# Authentication mode: "password" (default) or "none" (dev only)
AUTH_MODE=password

# ── Database (Azure Database for PostgreSQL) ──────────────────
# Azure Portal → Azure Database for PostgreSQL → Connection strings
# Format: postgresql://<user>:<password>@<host>:5432/<dbname>?sslmode=require
#
# Example (Flexible Server):
# DATABASE_URL=postgresql://adminuser:P@ssw0rd!@mccain-portal-db.postgres.database.azure.com:5432/portaldb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Azure OpenAI (Recommended for Azure deployments) ─────────
# Azure Portal → Azure OpenAI → Keys & Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>

# The deployment name you gave your model inside Azure OpenAI Studio
# (e.g. "gpt-4o" or whatever name you chose when deploying)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API version — 2024-08-01-preview works with gpt-4o on all Azure regions
# Leave this commented to use the default (2024-08-01-preview).
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Standard OpenAI (Alternative — not needed if using Azure OpenAI) ─
# Only set this if you are NOT using Azure OpenAI above.
# OPENAI_API_KEY=sk-...

# ── CORS ──────────────────────────────────────────────────────
# Set to your frontend URL so the browser allows cross-origin requests.
# If deploying frontend + API as a single App Service, leave this blank.
# If deploying separately (Static Web Apps + App Service), set it:
# ALLOWED_ORIGIN=https://<your-static-webapp>.azurestaticapps.net
ALLOWED_ORIGIN=

# ── Azure Storage (optional — for TDD document blob storage) ─
# Azure Portal → Storage Account → Access keys → Connection string
# If not set, TDD documents are stored in the database only.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=tdd-documents

# ── Azure IaC Deployment Feature ─────────────────────────────
# Required only if users will trigger live Azure resource deployments from the portal.
# Azure Portal → Azure Active Directory → App registrations → New registration
#   → Certificates & secrets → New client secret
# Then grant the Service Principal "Contributor" on your subscription.
# AZURE_TENANT_ID=<your-tenant-id>
# AZURE_CLIENT_ID=<your-app-registration-client-id>
# AZURE_CLIENT_SECRET=<your-client-secret>
# AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# ── Confluence Integration (optional) ────────────────────────
# For publishing TDD documents to Confluence.
# CONFLUENCE_BASE_URL=https://your-org.atlassian.net
# CONFLUENCE_USERNAME=your-email@mccain.com
# CONFLUENCE_API_TOKEN=<your-atlassian-api-token>
# CONFLUENCE_SPACE_KEY=CLOUD
# CONFLUENCE_PARENT_PAGE_ID=123456

# ── Rate Limiting (optional tuning) ──────────────────────────
# TDD_GENERATE_RATE_LIMIT_WINDOW_MS=60000
# TDD_GENERATE_RATE_LIMIT_MAX=10
# TDD_GENERATE_MAX_TOKENS=16000

# ── Logging ──────────────────────────────────────────────────
# LOG_LEVEL=info
